{
  "name": "@edgarelmo/mesh-agent-cli",
  "version": "0.2.51",
  "private": false,
  "type": "module",
  "description": "Mesh terminal agent CLI. Zero-config: ships with a shared Mesh LLM proxy so no AWS credentials are needed.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dreddi-edit/mesh-agent-cli"
  },
  "homepage": "https://github.com/dreddi-edit/mesh-agent-cli",
  "bugs": {
    "url": "https://github.com/dreddi-edit/mesh-agent-cli/issues"
  },
  "bin": {
    "mesh": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "mesh-core/lib",
    "mesh-core/package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json && node scripts/minify.js",
    "start": "node dist/index.js",
    "minify": "node scripts/minify.js",
    "prepublishOnly": "npm run build",
    "bench:niah:mesh-cli": "tsx benchmarks/mesh-cli-niah.ts",
    "bench:swe:mesh-cli": "tsx benchmarks/mesh-cli-swe.ts"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1",
    "boxen": "^8.0.1",
    "dotenv": "^16.4.7",
    "enquirer": "^2.4.1",
    "keytar": "^7.9.0",
    "ora": "^9.4.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "glob": "^13.0.6",
    "terser": "^5.46.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
