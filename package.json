{
  "name": "@edgarelmo/mesh-agent-cli",
  "version": "0.2.72",
  "private": false,
  "type": "module",
  "description": "Mesh terminal agent CLI. Zero-config: ships with a shared Mesh LLM proxy so no AWS credentials are needed.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/dreddi-edit/mesh-agent-cli"
  },
  "homepage": "https://github.com/dreddi-edit/mesh-agent-cli",
  "bin": {
    "mesh": "./dist/index.js",
    "mesh-agent": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/minify.js",
    "dev": "tsx src/index.ts",
    "test": "node --test",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.cjs"
  },
  "files": [
    "dist",
    "scripts",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "boxen": "^7.1.1",
    "@supabase/supabase-js": "^2.39.7",
    "dotenv": "^16.4.5",
    "enquirer": "^2.4.1",
    "glob": "^10.3.10",
    "keytar": "^7.9.0",
    "marked": "^11.0.1",
    "marked-terminal": "^6.2.0",
    "ora": "^7.0.1",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.0",
    "@types/node": "^20.11.24",
    "terser": "^5.29.1",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
