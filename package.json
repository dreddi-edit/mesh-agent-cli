{
  "name": "@edgarelmo/mesh-agent-cli",
  "version": "0.3.15",
  "private": false,
  "type": "module",
  "description": "Mesh terminal agent CLI. Zero-config: ships with a shared Mesh LLM proxy so no AWS credentials are needed.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dreddi-edit/mesh-agent-cli.git"
  },
  "homepage": "https://github.com/dreddi-edit/mesh-agent-cli",
  "bin": {
    "mesh": "dist/index.js",
    "mesh-agent": "dist/index.js",
    "mesh-daemon": "dist/daemon.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/minify.js",
    "dev": "tsx src/index.ts",
    "test": "node scripts/run-tests.cjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "smoke:release": "node scripts/release-smoke.cjs",
    "smoke:published": "node scripts/published-install-smoke.cjs",
    "verify:release": "npm run typecheck && npm run build && npm run test && npm run smoke:release",
    "publish:dry-run": "npm publish --dry-run --access public",
    "eval": "tsx scripts/run-eval.ts",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run verify:release",
    "postinstall": "node scripts/postinstall.cjs"
  },
  "files": [
    "assets",
    "docs",
    "dist",
    "scripts",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.7",
    "@xenova/transformers": "^2.17.2",
    "boxen": "^7.1.1",
    "dotenv": "^16.4.5",
    "enquirer": "^2.4.1",
    "glob": "^13.0.6",
    "ignore": "^7.0.5",
    "marked": "^11.0.1",
    "marked-terminal": "^6.2.0",
    "ora": "^7.0.1",
    "picocolors": "^1.0.0",
    "ts-morph": "^24.0.0",
    "z3-solver": "^4.13.0"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.0",
    "@types/node": "^20.11.24",
    "terser": "^5.29.1",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "protobufjs": "^7.5.5"
  }
}
