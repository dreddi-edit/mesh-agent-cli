{
  "name": "@edgarelmo/mesh-agent-cli",
  "version": "0.3.4",
  "private": false,
  "type": "module",
  "description": "Mesh terminal agent CLI. Zero-config: ships with a shared Mesh LLM proxy so no AWS credentials are needed.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/dreddi-edit/mesh-agent-cli"
  },
  "homepage": "https://github.com/dreddi-edit/mesh-agent-cli",
  "bin": {
    "mesh": "./dist/index.js",
    "mesh-agent": "./dist/index.js",
    "mesh-daemon": "./dist/daemon.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/minify.js",
    "dev": "tsx src/index.ts",
    "test": "node scripts/run-tests.cjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "eval": "tsx scripts/run-eval.ts",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.cjs"
  },
  "files": [
    "assets",
    "dist",
    "scripts",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.7",
    "@xenova/transformers": "^2.17.2",
    "boxen": "^7.1.1",
    "dotenv": "^16.4.5",
    "enquirer": "^2.4.1",
    "glob": "^11.0.0",
    "ignore": "^7.0.5",
    "keytar": "^7.9.0",
    "marked": "^11.0.1",
    "marked-terminal": "^6.2.0",
    "ora": "^7.0.1",
    "picocolors": "^1.0.0",
    "ts-morph": "^24.0.0",
    "z3-solver": "^4.13.0"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.0",
    "@types/node": "^20.11.24",
    "terser": "^5.29.1",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "protobufjs": "^7.5.5"
  }
}
