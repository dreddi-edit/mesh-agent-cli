{
  "name": "@edgarelmo/mesh-agent-cli",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "description": "Mesh terminal agent CLI. Zero-config: ships with a shared Mesh LLM proxy so no AWS credentials are needed.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dreddi-edit/mesh-agent-cli"
  },
  "homepage": "https://github.com/dreddi-edit/mesh-agent-cli",
  "bugs": {
    "url": "https://github.com/dreddi-edit/mesh-agent-cli/issues"
  },
  "bin": {
    "mesh-agent": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "mesh-core/src",
    "mesh-core/package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
