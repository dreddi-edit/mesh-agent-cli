{
  "name": "@dreddi-edit/mesh-agent-cli",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Mesh terminal agent CLI with local mode and optional MCP backend.",
  "bin": {
    "mesh-agent": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "mesh-core"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
