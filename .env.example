# mesh-agent-cli environment — EVERYTHING IS OPTIONAL.
#
# By default the CLI talks to the shared Mesh LLM proxy which injects the
# Bedrock API key server-side. You only need to set anything here for:
#   - overriding the model
#   - pointing at your own proxy / direct Bedrock (BYOK)
#   - switching to MCP mode

# --- LLM (optional) ---

# Override the LLM endpoint base. Defaults to the Mesh shared proxy.
# Example for BYOK direct-to-Bedrock:
#   BEDROCK_ENDPOINT=https://bedrock-runtime.us-east-1.amazonaws.com
# BEDROCK_ENDPOINT=

# Required ONLY for BYOK mode (direct Bedrock). Leave empty when using the
# Mesh shared proxy or your own proxy that injects auth server-side.
# AWS_BEARER_TOKEN_BEDROCK=
# BEDROCK_BEARER_TOKEN=
# BEDROCK_API_KEY=

# Bedrock model id. Defaults to a US inference-profile id for Claude Sonnet 4.6.
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Optional comma-separated fallback models used for 429/5xx transient failures.
# BEDROCK_FALLBACK_MODEL_IDS=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Inference tuning.
# BEDROCK_TEMPERATURE=0
# BEDROCK_MAX_TOKENS=1200

# --- Agent (optional) ---

# Max tool steps per turn before stopping.
# AGENT_MAX_STEPS=8

# Agent mode: local (default) or mcp.
# AGENT_MODE=local

# Local-mode workspace root. Defaults to CWD.
# WORKSPACE_ROOT=.

# --- MCP mode (only when AGENT_MODE=mcp) ---

# MESH_MCP_COMMAND=node
# MESH_MCP_ARGS=["/absolute/path/to/mesh-mcp-dist/dist/index.js"]

# --- Capsule cache (optional) ---
#
# When set, generated file capsules are stored in Supabase as an L2 cache.
# This allows team members to share capsule caches across machines.
# Without these vars the CLI works fully offline using only the local /tmp L1 cache.
#
# SUPABASE_URL=https://<your-project-ref>.supabase.co
# SUPABASE_KEY=<your-anon-public-key>
