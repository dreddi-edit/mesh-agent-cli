# Bedrock or Bedrock-compatible gateway endpoint used by the CLI.
# Example direct Bedrock runtime URL shape:
# https://bedrock-runtime.<region>.amazonaws.com/model/<model-id>/converse
BEDROCK_ENDPOINT=

# Optional bearer token used for direct Bedrock auth.
# Leave empty when BEDROCK_ENDPOINT points to your central proxy
# that injects Bedrock auth server-side.
AWS_BEARER_TOKEN_BEDROCK=

# Optional model ID if your endpoint expects it in payload.
BEDROCK_MODEL_ID=

# Optional tuning
BEDROCK_TEMPERATURE=0
BEDROCK_MAX_TOKENS=1200
AGENT_MAX_STEPS=8

# Agent mode: local (default) or mcp
AGENT_MODE=local

# Local mode workspace root (default: current working directory)
WORKSPACE_ROOT=.

# MCP server launch configuration (used only when AGENT_MODE=mcp)
# Example:
# MESH_MCP_COMMAND=node
# MESH_MCP_ARGS=["/absolute/path/to/mesh-mcp-dist/dist/index.js"]
MESH_MCP_COMMAND=
MESH_MCP_ARGS=[]
